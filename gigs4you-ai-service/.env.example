# Anthropic (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gigs4you
DB_USER=admin
DB_PASSWORD=CHANGE_THIS
# DATABASE_URL=postgresql://admin:password@localhost:5432/gigs4you

# JWT validation (must match the NestJS API)
JWT_SECRET=replace_with_same_jwt_secret_used_by_api

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service configuration
PORT=8001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173
NEST_API_URL=http://localhost:3000/api/v1

# Optional model overrides
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_FAST_MODEL=claude-3-5-haiku-20241022
