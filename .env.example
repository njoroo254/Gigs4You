# ══════════════════════════════════════════════════════════════════════════════
# Gigs4You — Production Environment Variables
# Copy this file to .env and fill in every value before deploying.
# NEVER commit .env to version control.
#
# How to generate secrets:
#   Random 64-char hex:  openssl rand -hex 64
#   Random base64:       openssl rand -base64 48
# ══════════════════════════════════════════════════════════════════════════════


# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_PORT=3000
APP_VERSION=1.0.0
BODY_SIZE_LIMIT=2mb
AI_SERVICE_URL=http://gigs4you-ai-service:8001


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Used by docker-compose AND by the NestJS API.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gigs4you
DB_USER=gigs4you_app
DB_PASSWORD=CHANGE_ME_strong_db_password_here

# Also used by docker-compose postgres service
POSTGRES_USER=gigs4you_app
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here

# Connection pool (tune based on VPS RAM — 20 is fine for 4 GB RAM)
DB_POOL_SIZE=20
DB_POOL_MIN=2


# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=GENERATE_A_64_CHAR_HEX_STRING_HERE
# MUST be different from JWT_SECRET. Generate: openssl rand -hex 64
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_CHAR_HEX_STRING_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d


# ── PII Field Encryption (AES-256-GCM) ───────────────────────────────────────
# Encrypts phone numbers and email addresses at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_STRING_HERE
# Separate key used for HMAC blind indexes (enables searching encrypted fields).
PII_HMAC_KEY=GENERATE_A_DIFFERENT_64_CHAR_HEX_STRING_HERE


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379


# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
# Used by docker-compose minio service AND by the NestJS API.
MINIO_ROOT_USER=CHANGE_ME_minio_admin_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password

S3_ENDPOINT=http://minio:9000
S3_BUCKET=gigs4you
S3_ACCESS_KEY=CHANGE_ME_minio_admin_user
S3_SECRET_KEY=CHANGE_ME_strong_minio_password
S3_REGION=us-east-1
# Public URL for images served through Nginx reverse proxy
S3_PUBLIC_URL=https://storage.gigs4you.co.ke/gigs4you


# ── M-Pesa / Daraja (apply at developer.safaricom.co.ke) ─────────────────────
MPESA_ENV=production
MPESA_CONSUMER_KEY=YOUR_DARAJA_PRODUCTION_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_DARAJA_PRODUCTION_CONSUMER_SECRET
MPESA_SHORTCODE=YOUR_TILL_OR_PAYBILL_NUMBER
MPESA_PAYBILL=YOUR_PAYBILL_NUMBER
MPESA_PASSKEY=YOUR_PRODUCTION_PASSKEY_FROM_SAFARICOM
MPESA_INITIATOR_NAME=YOUR_API_INITIATOR_NAME
MPESA_SECURITY_CREDENTIAL=YOUR_BASE64_ENCRYPTED_SECURITY_CREDENTIAL
MPESA_STK_CALLBACK_URL=https://api.gigs4you.co.ke/api/v1/billing/mpesa-stk-callback
MPESA_B2C_RESULT_URL=https://api.gigs4you.co.ke/api/v1/mpesa/b2c-result
MPESA_B2C_QUEUE_URL=https://api.gigs4you.co.ke/api/v1/mpesa/b2c-queue
MPESA_BALANCE_RESULT_URL=https://api.gigs4you.co.ke/api/v1/mpesa/balance-result


# ── Stripe (optional — international card payments) ───────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_LIVE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET


# ── Flutterwave (optional — alternative card gateway) ────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-YOUR_LIVE_PUBLIC_KEY
FLUTTERWAVE_SECRET_KEY=FLWSECK-YOUR_LIVE_SECRET_KEY
FLUTTERWAVE_SECRET_HASH=YOUR_FLUTTERWAVE_WEBHOOK_SECRET_HASH


# ── Africa's Talking (SMS — at.africastalking.com) ───────────────────────────
AT_API_KEY=YOUR_PRODUCTION_AT_API_KEY
AT_USERNAME=YOUR_AT_REGISTERED_USERNAME
AT_SENDER_ID=Gigs4You


# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail: use App Password (myaccount.google.com → Security → App Passwords)
# SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=SG.xxx
# Resend:   host=smtp.resend.com,   port=465, user=resend, pass=re_xxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_google_workspace_email@gigs4you.co.ke
SMTP_PASS=YOUR_APP_PASSWORD_NOT_ACCOUNT_PASSWORD
SMTP_FROM=noreply@gigs4you.co.ke


# ── Firebase Cloud Messaging (FCM push notifications) ─────────────────────────
# Paste the entire JSON content of the service account key file as a single line.
# Download from Firebase Console → Project Settings → Service Accounts → Generate Key
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@YOUR_PROJECT_ID.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}


# ── Sentry (error monitoring — sentry.io) ────────────────────────────────────
SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX


# ── Anthropic / AI Service ────────────────────────────────────────────────────
# Used by gigs4you-ai-service (FastAPI Python service)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# AI service environment
ENV=production


# ── Monitoring ────────────────────────────────────────────────────────────────
# Grafana admin password (access at https://grafana.gigs4you.co.ke)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password

# Bearer token Prometheus uses when scraping the /metrics endpoint
METRICS_TOKEN=GENERATE_A_RANDOM_TOKEN_HERE

# Slack incoming webhook URLs for alertmanager
# Create at api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_OPS=https://hooks.slack.com/services/T.../B.../xxx
SLACK_WEBHOOK_PAYMENTS=https://hooks.slack.com/services/T.../B.../xxx
SLACK_WEBHOOK_DEV=https://hooks.slack.com/services/T.../B.../xxx


# ── Seed (dev/staging only — leave empty in production) ──────────────────────
SEED_SECRET=
