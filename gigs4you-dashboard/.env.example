# ── Gigs4You Dashboard — Environment Variables ──────────────────────────
# Copy to .env.local for local dev, .env.production for production build
# Vite reads VITE_* vars only

# API base URL — change to your deployed API domain in production
VITE_API_URL=http://localhost:3000/api/v1

# Sentry error monitoring (optional but recommended in production)
VITE_SENTRY_DSN=

# App version shown in settings
VITE_APP_VERSION=1.0.0
