# ──────────────────────────────────────────────────────────────────────
# Gigs4You API — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_VERSION=1.0.0

# ── Database (PostgreSQL) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gigs4you
DB_USER=your_db_username
DB_PASSWORD=your_strong_db_password

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_minimum_64_characters_long_random_string_here
# REQUIRED — must be different from JWT_SECRET. Generate: openssl rand -hex 64
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_64_chars_different_from_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── PII Field Encryption ─────────────────────────────────────────────
# AES-256-GCM key for encrypting phone and email in the database.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — must each be a unique 64-character hex string.
PII_ENCRYPTION_KEY=generate_a_64_char_hex_string_here_for_aes_256_gcm_encryption
PII_HMAC_KEY=generate_a_different_64_char_hex_string_here_for_hmac_blind_indexes

# ── Database Pool ─────────────────────────────────────────────────────
DB_POOL_SIZE=20
DB_POOL_MIN=2

# ── S3 / MinIO Object Storage ─────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=gigs4you
S3_ACCESS_KEY=your_minio_access_key
S3_SECRET_KEY=your_minio_secret_key
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/gigs4you

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Firebase / FCM Push Notifications ────────────────────────────────
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id"}

# ── M-Pesa / Daraja ──────────────────────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PAYBILL=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_SECURITY_CREDENTIAL=your_security_credential
MPESA_B2C_RESULT_URL=https://yourdomain.com/api/v1/mpesa/b2c-result
MPESA_STK_CALLBACK_URL=https://yourdomain.com/api/v1/billing/mpesa-stk-callback
MPESA_BALANCE_RESULT_URL=https://yourdomain.com/api/v1/mpesa/balance-result

# ── Stripe (optional) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Africa's Talking (SMS) ────────────────────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=YourSenderID

# ── Email / SMTP ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourdomain.com

# ── Sentry (error monitoring) ─────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here

# ── Seed ──────────────────────────────────────────────────────────────
SEED_SECRET=your_secure_seed_secret_here
MPESA_B2C_QUEUE_URL=https://yourdomain.com/api/v1/mpesa/b2c-queue

# ── Flutterwave ───────────────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_SECRET_HASH=your_flutterwave_secret_hash

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Africa's Talking SMS ──────────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=Gigs4You

# ── Email / SMTP ──────────────────────────────────────────────────────
# For SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=SG.xxx
# For Resend:   host=smtp.resend.com,   port=465, user=resend, pass=re_xxx
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gigs4you.app

# ── Sentry Error Monitoring ───────────────────────────────────────────
SENTRY_DSN=

# ── Seed / Setup ──────────────────────────────────────────────────────
SEED_SECRET=gigs4you-seed-2024
